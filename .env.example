# ============================================================
# 飞书应用凭证（机器人身份 - 用于 WebSocket 长连接交互）
# ============================================================
# 创建自建应用后，在「应用凭证」页面获取
# 路径：飞书开放平台 → 你的应用 → 基础信息 → 应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 飞书 Webhook URL（单向推送消息到群 - 可选）
# ============================================================
# 在飞书群添加「自定义机器人」后获取
# 路径：群设置 → 群机器人 → 添加机器人 → 自定义机器人
# 如果只需要 @机器人 交互式分析论文，此项可不填
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================================
# Anthropic 兼容 API（SDK 直调论文分析用）
# ============================================================
# 如果使用第三方兼容端点（如 z.ai），同时设置 ANTHROPIC_BASE_URL
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# 模型名称（可选，默认 glm-5）
ANTHROPIC_MODEL=glm-5

# ============================================================
# API 服务配置（可选，默认 0.0.0.0:8000）
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# 论文分析配置
# ============================================================
# 分析超时时间（秒）
ANALYSIS_TIMEOUT=600
# 分析格式：quick | notes | deep
ANALYSIS_FORMAT=quick

# ============================================================
# GPU / MinerU 配置
# ============================================================
MINERU_GPU_DEVICE=0
MINERU_BACKEND=pipeline

# ============================================================
# Hugging Face Papers 推送时间（可选，默认 09:00）
# ============================================================
HF_PAPERS_SCHEDULE_TIME=09:00
